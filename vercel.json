{
  "version": 2,
  "routes": [
    {
      "src": "/scorecard",
      "dest": "/scorecard/index.html"
    },
    {
      "src": "/scorecard/thank-you",
      "dest": "/scorecard/thank-you.html"
    },
    {
      "src": "/scorecard/assessment",
      "dest": "/scorecard/assessment.html"
    },
    {
      "src": "/scorecard/(.*)",
      "dest": "/scorecard/$1"
    },
    {
      "src": "/thank-you",
      "dest": "/thank-you.html"
    },
    {
      "src": "/downloads/(.*)",
      "dest": "/downloads/$1"
    },
    {
      "src": "/app",
      "dest": "/app/index.html"
    },
    {
      "src": "/app/(.*)",
      "dest": "/app/$1"
    }
  ]
}
